{
  "name": "ai-ready-data-docs",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "validate": "node scripts/validate-docs.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint:docs": "markdownlint-cli2",
    "check": "npm run validate && npm run typecheck && npm run lint:docs && npm run docs:build"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "csv-parse": "7.0.1",
    "markdown-it-task-lists": "2.1.1",
    "markdownlint-cli2": "0.23.1",
    "mermaid": "11.16.0",
    "typescript": "5.9.3",
    "vitepress": "1.6.4",
    "vue": "3.5.40",
    "vue-tsc": "3.3.7",
    "yaml": "2.9.0"
  }
}
